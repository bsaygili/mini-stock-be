<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>Kritik Stok Uyarısı</title>
  </head>
  <body style="font-family:Arial,sans-serif; background:#f9f9f9; padding:20px;">

    <h2 style="background:#ff4d4f;color:#fff;padding:12px;border-radius:4px;">
        ⚠ Kritik Stok Ürünleri ({{criticalProducts.length}})
    </h2>
    <p style="font-size:14px;">Aşağıdaki ürünler kritik stok seviyesinde. Lütfen gerekli önlemleri alın.</p>

    <table style="width:100%; border-collapse:collapse; margin-top:10px;">
      <thead>
        <tr>
          <th style="border:1px solid #ccc; padding:8px; background:#f0f0f0; text-align:left;">Ürün</th>
          <th style="border:1px solid #ccc; padding:8px; background:#f0f0f0; text-align:right;">Mevcut Stok</th>
          <th style="border:1px solid #ccc; padding:8px; background:#f0f0f0; text-align:right;">Kritik Stok</th>
          <th style="border:1px solid #ccc; padding:8px; background:#f0f0f0; text-align:right;">Minimum Sipariş</th>
        </tr>
      </thead>
      <tbody>
        {{#criticalProducts}}
        <tr style="border-bottom:1px solid #ddd; {{#isCritical}}background:#ffe5e5;{{/isCritical}}">
          <td style="padding:6px;">{{productCode}} - {{productName}}</td>
          <td style="padding:6px; text-align:right;">{{stockQty}}</td>
          <td style="padding:6px; text-align:right;">{{criticalStockQty}}</td>
          <td style="padding:6px; text-align:right;">{{minOrderQty}}</td>
        </tr>
        {{/criticalProducts}}
      </tbody>
    </table>

    <p style="margin-top:15px; font-size:12px; color:#888; text-align:center;">
      Powered by Saygılı
    </p>

  </body>
</html>